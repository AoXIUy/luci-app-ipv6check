#!/bin/sh /etc/rc.common
# IPv6 连通性检测服务 - procd init 脚本

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/ipv6check

start_service() {
	local enabled
	config_load ipv6check
	config_get enabled global enabled 1

	[ "$enabled" != "1" ] && return

	procd_open_instance
	procd_set_param command "$PROG" --daemon
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile /var/run/ipv6check.pid
	procd_close_instance
}

stop_service() {
	# procd 会自动处理停止逻辑
	:
}

service_triggers() {
	procd_add_reload_trigger "ipv6check"
}

reload_service() {
	stop
	start
}
