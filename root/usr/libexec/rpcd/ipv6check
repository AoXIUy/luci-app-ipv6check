#!/bin/sh
# IPv6 连通性检测 - rpcd RPC 后端
# 为 LuCI 前端提供数据查询和操作接口

. /lib/functions.sh

STATUS_DIR="/tmp/ipv6check"
STATUS_FILE="${STATUS_DIR}/status.json"
LOG_FILE="${STATUS_DIR}/check.log"

# 封装为函数以确保 local 关键字合法
do_get_log() {
	local lines
	lines=$(jsonfilter -e '@.lines' 2>/dev/null)
	[ -z "$lines" ] && lines=50

	if [ -f "$LOG_FILE" ]; then
		local log_content
		log_content=$(tail -n "$lines" "$LOG_FILE" | sed 's/"/\\"/g' | awk '{printf "%s\\n", $0}')
		printf '{"log":"%s","lines":%d}' "$log_content" "$lines"
	else
		echo '{"log":"暂无日志","lines":0}'
	fi
}

do_get_restart_history() {
	if [ -f "${STATUS_DIR}/restart_history" ]; then
		local history
		history=$(cat "${STATUS_DIR}/restart_history" | sed 's/"/\\"/g' | awk '{printf "%s\\n", $0}')
		printf '{"history":"%s"}' "$history"
	else
		echo '{"history":"暂无重启记录"}'
	fi
}

do_run_check() {
	mkdir -p "$STATUS_DIR"
	/usr/bin/ipv6check --once >/dev/null 2>&1
	if [ -f "$STATUS_FILE" ]; then
		cat "$STATUS_FILE"
	else
		echo '{"overall":"error","check_time":"检测失败"}'
	fi
}

do_restart_interface() {
	local iface
	iface=$(jsonfilter -e '@.interface' 2>/dev/null)
	[ -z "$iface" ] && {
		config_load ipv6check
		config_get iface global restart_interface wan6
	}

	local timestamp
	timestamp=$(date '+%Y-%m-%d %H:%M:%S')

	mkdir -p "$STATUS_DIR"
	logger -t ipv6check "手动重启接口: ${iface}"
	echo "${timestamp} | 手动重启接口 ${iface}" >> "${STATUS_DIR}/restart_history"

	ifdown "$iface" 2>/dev/null
	sleep 3
	ifup "$iface" 2>/dev/null

	printf '{"result":"ok","interface":"%s","time":"%s"}' "$iface" "$timestamp"
}

do_get_interfaces() {
	local ifaces
	ifaces=$(ubus call network.interface dump 2>/dev/null)
	if [ -n "$ifaces" ]; then
		local list=""
		local first=1
		# 使用 jsonfilter 正确提取接口名
		for iface in $(echo "$ifaces" | jsonfilter -e '@.interface[*].interface' 2>/dev/null); do
			if [ "$first" = "1" ]; then
				list="\"${iface}\""
				first=0
			else
				list="${list},\"${iface}\""
			fi
		done
		printf '{"interfaces":[%s]}' "$list"
	else
		# 回退方案: 从 UCI 读取
		local list=""
		local first=1
		for iface in $(uci show network 2>/dev/null | grep '=interface' | cut -d. -f2 | cut -d= -f1); do
			if [ "$first" = "1" ]; then
				list="\"${iface}\""
				first=0
			else
				list="${list},\"${iface}\""
			fi
		done
		printf '{"interfaces":[%s]}' "$list"
	fi
}

case "$1" in
	list)
		# 声明可用的 RPC 方法及其参数
		echo '{"get_status":{},"get_log":{"lines":50},"get_restart_history":{},"run_check":{},"restart_interface":{"interface":"wan6"},"get_interfaces":{}}'
		;;

	call)
		case "$2" in
			get_status)
				if [ -f "$STATUS_FILE" ]; then
					cat "$STATUS_FILE"
				else
					echo '{"overall":"unknown","check_time":"从未检测","targets":[],"total_targets":0,"failed_targets":0,"consecutive_failures":0}'
				fi
				;;

			get_log)
				do_get_log
				;;

			get_restart_history)
				do_get_restart_history
				;;

			run_check)
				do_run_check
				;;

			restart_interface)
				do_restart_interface
				;;

			get_interfaces)
				do_get_interfaces
				;;
		esac
		;;
esac
